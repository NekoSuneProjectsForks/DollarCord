generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  username        String   @unique
  displayName     String
  passwordHash    String
  isPlatformAdmin Boolean  @default(false)
  bio             String?
  avatarUrl       String?
  twitchChannel   String?
  kickChannel     String?
  status            String    @default("ONLINE") // ONLINE | IDLE | DND | INVISIBLE
  customStatus      String?
  customStatusEmoji String?
  usernameChangedAt DateTime?
  rpcToken          String?   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions         Session[]
  activities       Activity[]
  passwordResets   PasswordResetToken[]
  mentions         Mention[]
  channelReadStates ChannelReadState[]
  threadReadStates ThreadReadState[]
  serverSupports   ServerSupporter[]
  ownedServers     Server[]                   @relation("ServerOwner")
  serverMembers    ServerMember[]
  messages         Message[]
  dmsSent          DirectMessage[]            @relation("DMSender")
  dmParticipants   DirectMessageParticipant[]
  reactionsGiven   Reaction[]
  pinnedBy         PinnedMessage[]            @relation("PinnedBy")
  serverBans       ServerBan[]                @relation("ServerBanUser")
  issuedServerBans ServerBan[]                @relation("ServerBanActor")
  createdBots      Bot[]                      @relation("BotCreator")
  serverSettings   ServerUserSettings[]
  createdEvents    ServerEvent[]              @relation("ServerEventCreator")
  eventRsvps       ServerEventParticipant[]
  friendsRequested Friendship[]               @relation("FriendRequester")
  friendsReceived  Friendship[]               @relation("FriendAddressee")
  activityHistory  ActivityHistory[]
  blocksMade       Block[]                    @relation("Blocker")
  blockedBy        Block[]                    @relation("Blocked")
  pollVotes        PollVote[]
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING") // PENDING | ACCEPTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Server {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  iconUrl               String?
  ownerId               String
  liveAnnounceChannelId String?  // channel to post "now live" announcements
  isPublic              Boolean  @default(false) // listed in server discovery
  plan                  String   @default("FREE") // FREE | GOLD (self-host overrides to SELF_HOSTED)
  planRenewsAt          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  owner        User                 @relation("ServerOwner", fields: [ownerId], references: [id])
  members      ServerMember[]
  channels     Channel[]
  invites      Invite[]
  bans         ServerBan[]
  roles        ServerRole[]
  memberRoles  ServerMemberRole[]
  bots         Bot[]
  userSettings ServerUserSettings[]
  events       ServerEvent[]
  categories   ChannelCategory[]
  supporters   ServerSupporter[]
  automod      ServerAutomod?
  emojis       ServerEmoji[]
}

model ServerEmoji {
  id        String   @id @default(cuid())
  serverId  String
  name      String
  url       String
  createdBy String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
}

// Per-server AutoMod configuration (keyword / mention-spam / invite filters).
model ServerAutomod {
  id           String   @id @default(cuid())
  serverId     String   @unique
  enabled      Boolean  @default(false)
  blockedWords String   @default("") // newline/comma separated
  maxMentions  Int      @default(0)  // 0 = unlimited
  blockInvites Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// "Server Supporters" — DollarCord's community-support/tier system (a boosting
// analogue, deliberately NOT a paid "Nitro"). Members can support a server to
// raise its tier and unlock cosmetic perks.
model ServerSupporter {
  id        String   @id @default(cuid())
  serverId  String
  userId    String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([serverId])
}

model ServerUserSettings {
  id                      String   @id @default(cuid())
  serverId                String
  userId                  String
  allowDms                Boolean  @default(true)
  messageRequests         Boolean  @default(false)
  shareActivity           Boolean  @default(true)
  activityJoining         Boolean  @default(true)
  muted                   Boolean  @default(false)
  notificationLevel       String   @default("ALL_MESSAGES") // ALL_MESSAGES | MENTIONS | NOTHING
  suppressEveryone        Boolean  @default(false)
  suppressRoleMentions    Boolean  @default(false)
  suppressHighlights      Boolean  @default(false)
  muteNewEvents           Boolean  @default(false)
  mobilePushNotifications Boolean  @default(true)
  inAppEventAlerts        Boolean  @default(true)
  pushEventAlerts         Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
}

model ServerMember {
  id       String   @id @default(cuid())
  serverId String
  userId   String
  role     String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  joinedAt DateTime @default(now())

  server Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles  ServerMemberRole[]

  @@unique([serverId, userId])
}

model ServerRole {
  id          String   @id @default(cuid())
  serverId    String
  name        String
  color       String   @default("#7c6af7")
  position    Int      @default(0)
  permissions Int      @default(0) // permission bitfield (see lib/permissions.ts)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server  Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members ServerMemberRole[]

  @@unique([serverId, name])
}

model ServerMemberRole {
  id        String   @id @default(cuid())
  serverId  String
  memberId  String
  roleId    String
  createdAt DateTime @default(now())

  server Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  member ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   ServerRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
}

model Bot {
  id        String   @id @default(cuid())
  serverId  String
  name      String
  username  String
  avatarUrl String?
  tokenHash String   @unique
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator  User      @relation("BotCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([serverId, username])
}

model ServerBan {
  id        String   @id @default(cuid())
  serverId  String
  userId    String
  bannedBy  String
  reason    String?
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation("ServerBanUser", fields: [userId], references: [id], onDelete: Cascade)
  actor  User   @relation("ServerBanActor", fields: [bannedBy], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  serverId  String
  createdBy String
  maxUses   Int?
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model Channel {
  id              String   @id @default(cuid())
  serverId        String
  categoryId      String?
  name            String
  description     String?
  type            String   @default("TEXT") // TEXT | VOICE | ANNOUNCEMENT | FORUM
  slowmodeSeconds Int      @default(0)
  nsfw            Boolean  @default(false)
  position        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  server         Server            @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category       ChannelCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages       Message[]
  pinnedMessages PinnedMessage[]
  events         ServerEvent[]
  readStates     ChannelReadState[]
  threads        Thread[]
  overrides      ChannelPermissionOverride[]
}

// Per-channel permission overrides. targetType: EVERYONE | ROLE | MEMBER.
// `allow`/`deny` are permission bitfields applied over the member's base perms.
model ChannelPermissionOverride {
  id         String   @id @default(cuid())
  channelId  String
  targetType String // EVERYONE | ROLE | MEMBER
  targetId   String // role id, user id, or "everyone"
  allow      Int      @default(0)
  deny       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, targetType, targetId])
  @@index([channelId])
}

model Thread {
  id            String   @id @default(cuid())
  channelId     String
  rootMessageId String?
  name          String
  createdBy     String
  archived      Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  channel    Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages   Message[]
  readStates ThreadReadState[]

  @@index([channelId])
}

model ThreadReadState {
  id         String   @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model ChannelCategory {
  id        String   @id @default(cuid())
  serverId  String
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels Channel[]
}

model ChannelReadState {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ServerEvent {
  id          String    @id @default(cuid())
  serverId    String
  channelId   String?
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  createdBy   String
  canceled    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  server       Server                   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel      Channel?                 @relation(fields: [channelId], references: [id], onDelete: SetNull)
  creator      User                     @relation("ServerEventCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants ServerEventParticipant[]
}

model ServerEventParticipant {
  id       String   @id @default(cuid())
  eventId  String
  userId   String
  notify   Boolean  @default(true)
  joinedAt DateTime @default(now())

  event ServerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Message {
  id               String   @id @default(cuid())
  channelId        String
  threadId         String?
  userId           String?
  botId            String?
  content          String
  edited           Boolean  @default(false)
  deleted          Boolean  @default(false)
  mentionsEveryone Boolean  @default(false)
  replyToId        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channel     Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  thread      Thread?         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User?           @relation(fields: [userId], references: [id])
  bot         Bot?            @relation(fields: [botId], references: [id])
  replyTo     Message?        @relation("MessageReply", fields: [replyToId], references: [id])
  replies     Message[]       @relation("MessageReply")
  reactions   Reaction[]
  pinnedIn    PinnedMessage[]
  attachments Attachment[]
  mentions    Mention[]
  poll        Poll?

  @@index([threadId])
  @@index([channelId, deleted, createdAt])
}

model Poll {
  id        String   @id @default(cuid())
  messageId String   @unique
  question  String
  multiple  Boolean  @default(false)
  closesAt  DateTime?
  createdAt DateTime @default(now())

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id       String @id @default(cuid())
  pollId   String
  text     String
  position Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, optionId, userId])
  @@index([pollId])
}

model Attachment {
  id          String   @id @default(cuid())
  messageId   String
  url         String
  name        String
  contentType String
  size        Int      @default(0)
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Mention {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model PinnedMessage {
  id        String   @id @default(cuid())
  channelId String
  messageId String
  pinnedBy  String
  createdAt DateTime @default(now())

  channel      Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message      Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedByUser User    @relation("PinnedBy", fields: [pinnedBy], references: [id])

  @@unique([channelId, messageId])
}

model DirectMessageThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants DirectMessageParticipant[]
  messages     DirectMessage[]
}

model DirectMessageParticipant {
  id       String @id @default(cuid())
  threadId String
  userId   String

  thread DirectMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model DirectMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  content   String
  edited    Boolean  @default(false)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread DirectMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User                @relation("DMSender", fields: [senderId], references: [id])
}

// Rich-presence activity. One row per (user, source) so an RPC client, a manual
// status, and a Twitch poller can each own an independent activity that we merge
// for display. `source` = "manual" | "rpc" | "twitch".
model Activity {
  id         String    @id @default(cuid())
  userId     String
  source     String    @default("manual")
  type       String    @default("PLAYING") // PLAYING | STREAMING | LISTENING | WATCHING | COMPETING | CUSTOM
  name       String
  details    String?
  state      String?
  url        String?
  largeImage String?
  smallImage String?
  startedAt  DateTime?
  expiresAt  DateTime?
  // "Join game" support: a join target + optional party occupancy.
  joinUrl      String?
  partyId      String?
  partyCurrent Int?
  partyMax     Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
  @@index([userId])
}

// Rolling history of games/apps a user has played (NOT streaming) — powers the
// "Recent activity" tab on profiles. One row per (user, name), refreshed on each
// sighting; queried for the last 30 days.
model ActivityHistory {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("PLAYING")
  name       String
  largeImage String?
  details    String?
  startedAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, lastSeenAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
