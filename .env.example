# Database
DATABASE_URL="file:./dev.db"

# Session secret - must be at least 32 characters
SESSION_SECRET="change-this-to-a-random-secret-at-least-32-chars"

# App URL (used for CORS)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Server port
PORT=3000

# Optional stream status integrations
# When set, Twitch live detection + the background "now streaming" poller activate.
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
KICK_CLIENT_ID=""
KICK_CLIENT_SECRET=""

# Self-hosting: set true to unlock the unlimited Self-Hosted tier for every server
# on this node. SELF_HOST_ACTIVATED_AT drives the "free forever before July 1 2026"
# early-adopter check.
SELF_HOSTED="false"
SELF_HOST_ACTIVATED_AT=""

# Cloud coordination (GameVox-style): when set, a self-host node uses the cloud
# only for auth federation / license / discovery — all voice/chat/file traffic
# stays on the node. Leave empty for a fully standalone node.
CLOUD_URL=""
NODE_ID=""

# Upload storage root. Defaults to ./public/uploads (served statically). Point this
# at a data volume to host several communities on one node — files are namespaced
# per server (<UPLOAD_ROOT>/<serverId>/...). A root outside ./public is streamed
# through /api/files. Example: UPLOAD_ROOT=/srv/dollarcord/data
UPLOAD_ROOT=""

# Optional TURN server for voice (required only for users behind symmetric NAT).
# STUN is always used; TURN is added when these are set. NEXT_PUBLIC_ so the
# browser WebRTC client can read them.
NEXT_PUBLIC_TURN_URL=""
NEXT_PUBLIC_TURN_USERNAME=""
NEXT_PUBLIC_TURN_CREDENTIAL=""
